					text = <"Excellent">
					description = <"">
				>
			>
		>
		["fr-ch"] = <
			items = <
				["at0000"] = <
					text = <"Knee arthroplasty satisfaction questionnaire">
					description = <"Mesure de résultat rapportée par le patient utilisée pour enregistrer la satisfaction après une arthroplastie du genou, y compris le soulagement perçu de la douleur, l’amélioration des activités, la satisfaction des attentes, le statut global, le score global de satisfaction et la disposition à subir à nouveau une intervention chirurgicale.">
				>
				["at0001"] = <
					text = <"History">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Any point-in-time event">
					description = <"@ internal @">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0005"] = <
					text = <"1. De quelle manière pensez-vous que votre intervention a supprimé la douleur au niveau de votre genou?">
					description = <"">
				>
				["at0011"] = <
					text = <"2. De quelle manière pensez-vous que votre intervention a augmenté votre capacité à réaliser vos activités habituelles?">
					description = <"">
				>
				["at0012"] = <
					text = <"Mauvaise">
					description = <"">
				>
				["at0013"] = <
					text = <"Moyenne">
					description = <"">
				>
				["at0014"] = <
					text = <"Bonne">
					description = <"">
				>
				["at0015"] = <
					text = <"Très bonne">
					description = <"">
				>
				["at0016"] = <
					text = <"Excellente">
					description = <"">
				>
				["at0017"] = <
					text = <"3. De quelle manière pensez-vous que votre intervention vous permet de réaliser maintenant des travaux lourds ou des activités sportives?">
					description = <"">
				>
				["at0018"] = <
					text = <"Mauvaise">
					description = <"">
				>
				["at0019"] = <
					text = <"Moyenne">
					description = <"">
				>
				["at0020"] = <
					text = <"Bonne">
					description = <"">
				>
				["at0021"] = <
					text = <"Très bonne">
					description = <"">
				>
				["at0022"] = <
					text = <"Excellente">
					description = <"">
				>
				["at0023"] = <
					text = <"4. De quelle manière pensez-vous que votre intervention finalement correspond à vos attentes?">
					description = <"">
				>
				["at0024"] = <
					text = <"Mauvaise">
					description = <"">
				>
				["at0025"] = <
					text = <"Moyenne">
					description = <"">
				>
				["at0026"] = <
					text = <"Bonne">
					description = <"">
				>
				["at0027"] = <
					text = <"Très bonne">
					description = <"">
				>
				["at0028"] = <
					text = <"Excellente">
					description = <"">
				>
				["at0029"] = <
					text = <"5. Globalement êtes-vous?">
					description = <"">
				>
				["at0030"] = <
					text = <"Déçu">
					description = <"">
				>
				["at0031"] = <
					text = <"Amélioré">
					description = <"">
				>
				["at0032"] = <
					text = <"Satisfait">
					description = <"">
				>
				["at0033"] = <
					text = <"6. Notez sur l’échelle ci-dessous le degré de satisfaction ressenti par rapport à votre prothèse de genou?">
					description = <"">
				>
				["at0034"] = <
					text = <"7. Aujourd’hui, vous referiez-vous opérer de votre genou?">
					description = <"">
				>
				["at0035"] = <
					text = <"Oui">
					description = <"">
				>
				["at0036"] = <
					text = <"Non">
					description = <"">
				>
				["at0037"] = <
					text = <"Raison pour ne pas subir à nouveau l’intervention chirurgical">
					description = <"">
				>
				["at0038"] = <
					text = <"Item tree">
					description = <"@ internal @">
				>
				["at0039"] = <
					text = <"Mauvaise">
					description = <"">
				>
				["at0040"] = <
					text = <"Moyenne">
					description = <"">
				>
				["at0041"] = <
