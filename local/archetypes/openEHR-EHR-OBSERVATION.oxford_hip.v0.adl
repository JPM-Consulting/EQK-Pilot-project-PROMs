					text = <"Tree">
					description = <"@ internal @">
				>
				["at0006"] = <
					text = <"Extension">
					description = <"Informations supplémentaires nécessaires pour prendre en compte le contexte local ou pour s’aligner sur d’autres modèles de référence / formalismes.">
					comment = <"Par exemple : informations sur le service hospitalier local ou métadonnées supplémentaires nécessaires pour s’aligner sur des équivalents HL7 ou CDISC.">
				>
				["at0008"] = <
					text = <"1. Comment décririez-vous la douleur que vous avez habituellement ressentie dans votre hanche?">
					description = <"">
				>
				["at0009"] = <
					text = <"Modérée">
					description = <"">
				>
				["at0010"] = <
					text = <"Légère">
					description = <"">
				>
				["at0011"] = <
					text = <"Minime">
					description = <"">
				>
				["at0012"] = <
					text = <"Aucune">
					description = <"">
				>
				["at0014"] = <
					text = <"2. Avez-vous eu des difficultés pour vous laver et vous sécher le corps vous-même?">
					description = <"">
				>
				["at0015"] = <
					text = <"Difficultés majeures">
					description = <"">
				>
				["at0016"] = <
					text = <"Aucune difficulté">
					description = <"">
				>
				["at0017"] = <
					text = <"Difficultés minimes">
					description = <"">
				>
				["at0018"] = <
					text = <"Difficultés modérées">
					description = <"">
				>
				["at0019"] = <
					text = <"Impossible à réaliser">
					description = <"">
				>
				["at0020"] = <
					text = <"3. Avez-vous eu des difficultés à cause de votre hanche pour entrer ou sortir d’une voiture ou pour utiliser les transports en commun (quel que soit le mode de transport utilisé)?">
					description = <"">
				>
				["at0021"] = <
					text = <"Impossible à réaliser">
					description = <"">
				>
				["at0022"] = <
					text = <"Difficultés majeures">
					description = <"">
				>
				["at0023"] = <
					text = <"Difficultés modérées">
					description = <"">
				>
				["at0024"] = <
					text = <"Difficultés minimes">
					description = <"">
				>
				["at0025"] = <
					text = <"Aucune difficulté">
					description = <"">
				>
				["at0026"] = <
					text = <"4. Avez-vous été capable de mettre seul(e) vos bas, collants ou chaussettes?">
					description = <"">
				>
				["at0027"] = <
					text = <"Non impossible">
					description = <"">
				>
				["at0028"] = <
					text = <"Avec beaucoup de difficultés">
					description = <"">
