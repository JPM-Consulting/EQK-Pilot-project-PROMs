definition
	OBSERVATION[at0000] matches {    -- Oxford Hip Questionnaire Score (OHS)
		data matches {
			HISTORY[at0001] matches {    -- Event Series
				events cardinality matches {1..*; unordered} matches {
					POINT_EVENT[at0002] occurrences matches {0..1} matches {    -- Any point-in-time event
						data matches {
							ITEM_TREE[at0003] matches {    -- Tree
								items cardinality matches {0..*; unordered} matches {
									ELEMENT[at0008] occurrences matches {0..1} matches {    -- 1. How would you describe the pain you usually have from your hip?
										value matches {
											4|[local::at0012],
											3|[local::at0011],
											2|[local::at0010],
											1|[local::at0009],
											0|[local::at0109]
										}
									}
									ELEMENT[at0014] occurrences matches {0..1} matches {    -- 2. Have you had any trouble with washing and drying yourself (all over) because of your hip?
										value matches {
											4|[local::at0016],
											3|[local::at0017],
											2|[local::at0018],
											1|[local::at0015],
											0|[local::at0019]
										}
									}
									ELEMENT[at0020] occurrences matches {0..1} matches {    -- 3. Have you had any trouble getting in and out of a car or using public transport because of your hip? (whichever you tend to use)
										value matches {
											4|[local::at0025],
											3|[local::at0024],
											2|[local::at0023],
											1|[local::at0022],
											0|[local::at0021]
										}
									}
									ELEMENT[at0026] occurrences matches {0..1} matches {    -- 4. Have you been able to put on a pair of socks, stockings or tights?
										value matches {
											4|[local::at0031],
											3|[local::at0030],
											2|[local::at0029],
											1|[local::at0028],
											0|[local::at0027]
										}
									}
									ELEMENT[at0032] occurrences matches {0..1} matches {    -- 5. Could you do the household shopping on your own?
										value matches {
											4|[local::at0037],
											3|[local::at0036],
											2|[local::at0035],
											1|[local::at0034],
											0|[local::at0033]
										}
									}
									ELEMENT[at0038] occurrences matches {0..1} matches {    -- 6. For how long have you been able to walk before pain from your hip becomes severe? (with or without a stick)
										value matches {
											4|[local::at0043],
											3|[local::at0042],
											2|[local::at0041],
											1|[local::at0040],
											0|[local::at0039]
										}
									}
									ELEMENT[at0044] occurrences matches {0..1} matches {    -- 7. Have you been able to climb a flight of stairs?
										value matches {
											4|[local::at0114],
											3|[local::at0113],
											2|[local::at0112],
											1|[local::at0111],
											0|[local::at0110]
										}
									}
									ELEMENT[at0050] occurrences matches {0..1} matches {    -- 8. After a meal (sat at a table), how painful has it been for you to stand up from a chair because of your hip?
										value matches {
											4|[local::at0055],
											3|[local::at0054],
											2|[local::at0053],
											1|[local::at0052],
											0|[local::at0051]
										}
									}
									ELEMENT[at0056] occurrences matches {0..1} matches {    -- 9. Have you been limping when walking, because of your hip?
										value matches {
											4|[local::at0061],
											3|[local::at0060],
											2|[local::at0059],
											1|[local::at0058],
											0|[local::at0057]
										}
									}
									ELEMENT[at0062] occurrences matches {0..1} matches {    -- 10. Have you had any sudden, severe pain - 'shooting', 'stabbing' or 'spasms' - from the affected hip?
										value matches {
											4|[local::at0067],
											3|[local::at0066],
											2|[local::at0065],
											1|[local::at0064],
											0|[local::at0063]
										}
									}
									ELEMENT[at0068] occurrences matches {0..1} matches {    -- 11. How much has pain from your hip interfered with your usual work (including housework)?
										value matches {
											4|[local::at0073],
											3|[local::at0072],
											2|[local::at0071],
											1|[local::at0070],
											0|[local::at0069]
										}
									}
									ELEMENT[at0074] occurrences matches {0..1} matches {    -- 12. Have you been troubled by pain from your hip in bed at night?
										value matches {
											4|[local::at0079],
											3|[local::at0078],
											2|[local::at0077],
											1|[local::at0076],
											0|[local::at0075]
										}
									}
									ELEMENT[at0104] occurrences matches {0..1} matches {    -- Total score
										value matches {
											DV_COUNT matches {
												magnitude matches {|0..48|}
											}
										}
									}
									ELEMENT[at0105] occurrences matches {0..1} matches {    -- Average score
										value matches {
											DV_COUNT matches {
												magnitude matches {|0..100|}
											}
										}
									}
									ELEMENT[at0115] occurrences matches {0..1} matches {    -- Grading
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0116,    -- Severe
													at0117,    -- Moderate to severe
													at0118,    -- Moderate
													at0119]    -- Satisfactory
												}
											}
										}
									}
									ELEMENT[at0120] occurrences matches {0..1} matches {    -- Pain score
										value matches {
											DV_COUNT matches {
												magnitude matches {|0..24|}
											}
										}
									}
									ELEMENT[at0121] occurrences matches {0..1} matches {    -- Function score
										value matches {
											DV_COUNT matches {
												magnitude matches {|0..24|}
											}
										}
									}
									ELEMENT[at0122] occurrences matches {0..1} matches {    -- Normalized pain score
										value matches {
											C_DV_QUANTITY <
												property = <[openehr::380]>
												list = <
													["1"] = <
														units = <"1">
														magnitude = <|0.0..100.0|>
													>
												>
											>
										}
									}
									ELEMENT[at0123] occurrences matches {0..1} matches {    -- Normalized function score
										value matches {
											C_DV_QUANTITY <
												property = <[openehr::380]>
												list = <
													["1"] = <
														units = <"1">
														magnitude = <|0.0..100.0|>
													>
												>
											>
										}
									}
								}
							}
						}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0005] matches {    -- Tree
				items cardinality matches {0..*; unordered} matches {
					allow_archetype CLUSTER[at0006] occurrences matches {0..1} matches {    -- Extension
						include
							archetype_id/value matches {/.*/}
					}
				}
			}
		}
	}

ontology
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Oxford Hip Questionnaire Score (OHS)">
					description = <"Oxford Hip Questionnaire Score (OHS).">
				>
				["at0001"] = <
					text = <"Event Series">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Any point-in-time event">
					description = <"A specific date and/or time which may be explicitly defined in a template or at run-time.">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0005"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0006"] = <
					text = <"Extension">
					description = <"Additional information required to capture local context or to align with other reference models/formalisms.">
					comment = <"e.g. Local hospital departmental infomation or additional metadata to align with HL7 or CDISC equivalents.">
				>
				["at0008"] = <
					text = <"1. How would you describe the pain you usually have from your hip?">
					description = <"Patient-reported extent of usual pain in hip during past 4 weeks.">
					comment = <"Questionnaire wording: 

How would you describe the pain you usually had from your hip?">
				>
