					text = <"Avec quelques difficultés">
					description = <"">
				>
				["at0030"] = <
					text = <"Avec très peu de difficultés">
					description = <"">
				>
				["at0031"] = <
					text = <"Oui facilement">
					description = <"">
				>
				["at0032"] = <
					text = <"5. Avez-vous pu faire tout(e) seul(e) des courses pour la maison?">
					description = <"">
				>
				["at0033"] = <
					text = <"Non impossible">
					description = <"">
				>
				["at0034"] = <
					text = <"Avec beaucoup de difficultés">
					description = <"">
				>
				["at0035"] = <
					text = <"Avec quelques difficultés">
					description = <"">
				>
				["at0036"] = <
					text = <"Avec très peu de difficultés">
					description = <"">
				>
				["at0037"] = <
					text = <"Oui facilement">
					description = <"">
				>
				["at0038"] = <
					text = <"6. Combien de temps pouviez-vous marcher (sans vous arrêter) avant que la douleur dans votre hanche ne devienne très importante (avec ou sans canne)?">
					description = <"">
				>
				["at0039"] = <
					text = <"Pas du tout ou douleur sévère à la marche">
					description = <"">
				>
				["at0040"] = <
					text = <"Autour de la maison seulement">
					description = <"">
				>
				["at0041"] = <
					text = <"De 5 à 15 minutes">
					description = <"">
				>
				["at0042"] = <
					text = <"De 16 à 30 minutes">
					description = <"">
				>
				["at0043"] = <
					text = <"Pas de douleur ou plus de 30 minutes">
					description = <"">
				>
				["at0044"] = <
					text = <"7. Avez-vous pu monter un étage par les escaliers?">
					description = <"">
				>
				["at0050"] = <
					text = <"8. Après être resté assis(e) (pour un repas par exemple), quel degré de douleur avez-vous ressenti en vous levant de la chaise à cause de votre hanche?">
					description = <"">
				>
				["at0051"] = <
					text = <"Insupportable">
					description = <"">
				>
				["at0052"] = <
					text = <"Très douloureux">
					description = <"">
				>
				["at0053"] = <
					text = <"Modérément douloureux">
					description = <"">
				>
				["at0054"] = <
					text = <"Légèrement douloureux">
					description = <"">
				>
				["at0055"] = <
					text = <"Pas douloureux du tout">
					description = <"">
				>
				["at0056"] = <
					text = <"9. Avez-vous boité en marchant à cause de votre hanche?">
					description = <"">
				>
				["at0057"] = <
					text = <"Tout le temps">
					description = <"">
				>
				["at0058"] = <
					text = <"La plupart du temps">
					description = <"">
				>
				["at0059"] = <
					text = <"Souvent, pas seulement au début">
					description = <"">
				>
				["at0060"] = <
					text = <"Quelques fois ou juste au début">
					description = <"">
				>
				["at0061"] = <
					text = <"Rarement ou jamais">
					description = <"">
				>
				["at0062"] = <
					text = <"10. Avez-vous ressenti au niveau de votre hanche malade une douleur soudaine, vive et intense (en coup de poignard, spasme, en vrille)?">
					description = <"">
				>
				["at0063"] = <
					text = <"Chaque jour">
					description = <"">
				>
				["at0064"] = <
					text = <"La plupart des jours">
					description = <"">
				>
				["at0065"] = <
					text = <"Quelques jours">
					description = <"">
				>
				["at0066"] = <
					text = <"Seulement 1 ou 2 jours">
					description = <"">
				>
				["at0067"] = <
					text = <"Jamais">
					description = <"">
				>
				["at0068"] = <
					text = <"11. La douleur de votre hanche vous-a-t-elle gêné(e) dans votre travail ou vos activités habituelles (tâches ménagères comprises)?">
					description = <"">
				>
				["at0069"] = <
					text = <"Tout le temps">
					description = <"">
				>
				["at0070"] = <
					text = <"Fortement">
					description = <"">
				>
				["at0071"] = <
					text = <"Modérément">
					description = <"">
				>
				["at0072"] = <
					text = <"Un peu">
					description = <"">
				>
				["at0073"] = <
					text = <"Pas du tout">
					description = <"">
				>
				["at0074"] = <
					text = <"12. Avez-vous souffert de douleurs de votre hanche au lit la nuit?">
					description = <"">
				>
				["at0075"] = <
					text = <"Toutes les nuits">
					description = <"">
				>
				["at0076"] = <
					text = <"La plupart des nuits">
					description = <"">
				>
				["at0077"] = <
					text = <"Quelques nuits">
					description = <"">
				>
				["at0078"] = <
					text = <"Seulement 1 ou 2 nuits">
					description = <"">
				>
				["at0079"] = <
					text = <"Jamais">
					description = <"">
				>
