					description = <"">
				>
				["at0014"] = <
					text = <"2. Avez-vous eu des difficultés à vous laver et à vous sécher entièrement à cause de votre genou?">
					description = <"">
				>
				["at0015"] = <
					text = <"Difficultés majeures">
					description = <"">
				>
				["at0016"] = <
