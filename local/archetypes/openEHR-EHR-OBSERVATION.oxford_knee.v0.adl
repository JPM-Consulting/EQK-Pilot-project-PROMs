				["at0018"] = <
					text = <"Difficultés modérées">
					description = <"">
				>
				["at0019"] = <
					text = <"Impossible à réaliser">
					description = <"">
				>
				["at0020"] = <
					text = <"3. Avez-vous eu des difficultés, à cause de votre genou, pour monter dans une voiture et en sortir ou pour utiliser les transports publics (selon le moyen de transport que vous utilisez habituellement)?">
					description = <"">
				>
				["at0021"] = <
					text = <"Impossible à réaliser">
					description = <"">
