				["at0036"] = <
					text = <"Légèrement douloureux">
					description = <"">
				>
				["at0037"] = <
					text = <"Pas douloureux du tout">
					description = <"">
				>
				["at0044"] = <
					text = <"11. Avez-vous pu faire seul(e) les courses du ménage?">
					description = <"">
				>
				["at0056"] = <
					text = <"6. Avez-vous boité en marchant à cause de votre genou?">
					description = <"">
