				["at0024"] = <
					text = <"Difficultés minimes">
					description = <"">
				>
				["at0025"] = <
					text = <"Aucune difficulté">
					description = <"">
				>
				["at0026"] = <
					text = <"4. Pendant combien de temps avez-vous pu marcher avant que la douleur de votre genou ne devienne importante? (avec ou sans canne)">
					description = <"">
				>
				["at0027"] = <
					text = <"Pas du tout ou douleur sévère à la marche">
					description = <"">
				>
				["at0028"] = <
					text = <"Autour de la maison seulement">
					description = <"">
				>
				["at0029"] = <
					text = <"De 5 à 15 minutes">
					description = <"">
				>
				["at0030"] = <
					text = <"De 16 à 30 minutes">
					description = <"">
				>
				["at0031"] = <
					text = <"Pas de douleur ou plus de 30 minutes">
					description = <"">
				>
				["at0032"] = <
					text = <"5. Après un repas (assis(e) à table), dans quelle mesure était-il douloureux pour vous de vous lever d’une chaise à cause de votre genou?">
					description = <"">
				>
				["at0033"] = <
					text = <"Insupportable">
					description = <"">
				>
				["at0034"] = <
					text = <"Très douloureux">
					description = <"">
				>
				["at0035"] = <
