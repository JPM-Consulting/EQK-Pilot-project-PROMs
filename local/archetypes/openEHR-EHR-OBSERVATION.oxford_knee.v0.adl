				["at0006"] = <
					text = <"Extension">
					description = <"Informations supplémentaires requises pour capturer le contexte local ou pour assurer l’alignement avec d’autres modèles de référence/formalismes.">
					comment = <"Par ex. informations relatives au service hospitalier local ou métadonnées supplémentaires permettant l’alignement avec des équivalents HL7 ou CDISC.">
				>
				["at0008"] = <
					text = <"1. Comment décririez-vous habituellement la douleur de votre genou?">
					description = <"">
				>
				["at0009"] = <
					text = <"Modérée">
					description = <"">
