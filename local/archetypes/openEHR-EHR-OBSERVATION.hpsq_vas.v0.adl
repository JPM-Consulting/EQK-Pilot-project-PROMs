		["build_uid"] = <"17d071e0-ac46-3ee5-8663-2adb97186838">
	>

definition
	OBSERVATION[at0000] matches {    -- Hip pain and stiffness VAS questionnaire (HPSQ-VAS)
		data matches {
			HISTORY[at0001] matches {    -- History
				events cardinality matches {1..*; unordered} matches {
					POINT_EVENT[at0002] occurrences matches {0..*} matches {    -- Any point-in-time event
						data matches {
							ITEM_TREE[at0003] matches {    -- Tree
								items cardinality matches {0..*; unordered} matches {
									CLUSTER[at0004] occurrences matches {0..1} matches {    -- For the hip to be operated on or already operated on
										items cardinality matches {1..*; unordered} matches {
											ELEMENT[at0006] occurrences matches {0..1} matches {    -- 1. What was the intensity of the pain in your hip during the past week?
												value matches {
													DV_COUNT matches {
														magnitude matches {|0..10|}
													}
												}
											}
											ELEMENT[at0007] occurrences matches {0..1} matches {    -- 2. What was the intensity of the stiffness in your hip during the past week?
												value matches {
													DV_COUNT matches {
														magnitude matches {|0..10|}
													}
												}
											}
										}
									}
									CLUSTER[at0005] occurrences matches {0..1} matches {    -- For the other hip / the healthy side
										items cardinality matches {1..*; unordered} matches {
											ELEMENT[at0008] occurrences matches {0..1} matches {    -- 1. What was the intensity of the pain in your hip during the past week?
												value matches {
													DV_COUNT matches {
														magnitude matches {|0..10|}
													}
												}
											}
											ELEMENT[at0009] occurrences matches {0..1} matches {    -- 2. What was the intensity of the stiffness in your hip during the past week?
												value matches {
													DV_COUNT matches {
														magnitude matches {|0..10|}
													}
												}
											}
										}
									}
								}
							}
						}
					}
				}
			}
		}
	}

ontology
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Hip pain and stiffness VAS questionnaire (HPSQ-VAS)">
					description = <"A patient-reported outcome measure used to record the intensity of pain and stiffness in the index hip and, where applicable, the contralateral hip using 0–10 visual analogue scale ratings.">
				>
				["at0001"] = <
					text = <"History">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Any point-in-time event">
					description = <"@ internal @">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"For the hip to be operated on or already operated on">
					description = <"">
				>
				["at0005"] = <
					text = <"For the other hip / the healthy side">
					description = <"">
				>
				["at0006"] = <
					text = <"1. What was the intensity of the pain in your hip during the past week?">
					description = <"">
					comment = <"higher values indicate worse symptoms
0 = no pain / no stiffness
10 = worst imaginable pain / extreme stiffness
">
				>
				["at0007"] = <
					text = <"2. What was the intensity of the stiffness in your hip during the past week?">
					description = <"">
					comment = <"higher values indicate worse symptoms
0 = no pain / no stiffness
10 = worst imaginable pain / extreme stiffness">
				>
				["at0008"] = <
					text = <"1. What was the intensity of the pain in your hip during the past week?">
					description = <"">
					comment = <"higher values indicate worse symptoms
0 = no pain / no stiffness
10 = worst imaginable pain / extreme stiffness">
				>
				["at0009"] = <
					text = <"2. What was the intensity of the stiffness in your hip during the past week?">
					description = <"">
					comment = <"higher values indicate worse symptoms
0 = no pain / no stiffness
10 = worst imaginable pain / extreme stiffness">
				>
			>
		>
