description
	original_author = <
		["date"] = <"2026-03-30">
		["name"] = <"Jean-Pierre Messerli">
		["organisation"] = <"JPM Consulting GmbH">
		["email"] = <"jean-pierre.messerli@jpm-consulting.ch">
	>
	lifecycle_state = <"unmanaged">
	details = <
		["fr-ch"] = <
			language = <[ISO_639-1::fr-ch]>
			purpose = <"Pour enregistrer l’intensité de la douleur et de la raideur rapportée par le patient dans la hanche index et la hanche controlatérale à l’aide d’échelles visuelles analogiques cotées de 0 à 10.">
			keywords = <"PROM, mesure de résultat rapportée par le patient, arthroplastie de la hanche, remplacement de la hanche, douleur de la hanche, raideur de la hanche, échelle visuelle analogique, EVA", ...>
			copyright = <"© openEHR Foundation">
			use = <"À utiliser pour enregistrer ou échanger l’intensité de la douleur et de la raideur rapportée par le patient dans la hanche devant être opérée ou déjà opérée et, le cas échéant, dans la hanche controlatérale. Orientation de l’échelle : 0 = aucune douleur ou aucune raideur ; 10 = douleur maximale imaginable ou raideur extrême. Des valeurs plus élevées indiquent des symptômes plus sévères.
">
			misuse = <"Ne pas utiliser pour enregistrer une mesure multidimensionnelle des résultats concernant la hanche ni un score récapitulatif calculé en dehors du contexte de ce questionnaire à échelle visuelle analogique.">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record patient-reported pain and stiffness intensity in the index hip and contralateral hip using 0–10 visual analogue scale ratings.">
			keywords = <"PROM","patient-reported","outcome","measure","hip","arthroplasty","hip","replacement","hip","pain","hip","stiffness","visual","analogue","scale","VAS">
			use = <"Use to record or exchange patient-reported pain and stiffness intensity in the hip to be operated on or already operated on and, where applicable, in the contralateral hip. Scale direction: 0 = no pain or no stiffness; 10 = worst imaginable pain or extreme stiffness. Higher values indicate worse symptoms.">
			misuse = <"Not to be used to record a multidimensional hip outcome measure or a calculated summary score outside the context of this visual analogue scale questionnaire.
">
		>
	>
	other_details = <
		["licence"] = <"This work is licensed under the Creative Commons Attribution-ShareAlike 4.0 International License. To view a copy of this license, visit http://creativecommons.org/licenses/by-sa/4.0/.">
		["custodian_organisation"] = <"openEHR Foundation">
		["original_namespace"] = <"org.openehr">
		["original_publisher"] = <"openEHR Foundation">
		["custodian_namespace"] = <"org.openehr">
