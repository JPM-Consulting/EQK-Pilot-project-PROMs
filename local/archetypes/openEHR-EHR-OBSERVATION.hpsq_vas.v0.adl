					description = <"Mesure de résultat rapportée par le patient utilisée pour enregistrer l’intensité de la douleur et de la raideur dans la hanche index et, le cas échéant, dans la hanche controlatérale, à l’aide d’échelles visuelles analogiques cotées de 0 à 10.">
				>
				["at0001"] = <
					text = <"History">
					description = <"@ internal @">
				>
