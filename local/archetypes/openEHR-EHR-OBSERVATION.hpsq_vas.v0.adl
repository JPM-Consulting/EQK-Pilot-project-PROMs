					text = <"Any point-in-time event">
					description = <"@ internal @">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"Pour la hanche à opérer ou déjà opérée">
					description = <"">
				>
				["at0005"] = <
					text = <"Pour l’autre hanche / le côté sain">
					description = <"">
				>
				["at0006"] = <
					text = <"1. Quelle fut l’intensité de la douleur dans votre hanche au cours de la semaine passée?">
					description = <"">
					comment = <"Des valeurs plus élevées indiquent des symptômes plus sévères.
0 = aucune douleur / aucune raideur
10 = douleur maximale imaginable / raideur extrême">
