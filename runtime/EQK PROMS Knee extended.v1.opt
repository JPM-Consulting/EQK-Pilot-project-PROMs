                <term_definitions code="at0004">
                    <items id="text">Mobility</items>
                    <items id="description">Issues with mobility.</items>
                </term_definitions>
                <term_definitions code="at0005">
                    <items id="text">No problems</items>
                    <items id="description">*</items>
                </term_definitions>
                <term_definitions code="at0006">
                    <items id="text">Self-care</items>
                    <items id="description">Issues with self-care.</items>
                </term_definitions>
                <term_definitions code="at0007">
                    <items id="text">Usual activities e.g. work, study, housework, family or leisure activities.</items>
                    <items id="description">Issues with usual activities.</items>
                    <items id="comment">e.g. work, study, housework, family or leisure activities.</items>
                </term_definitions>
                <term_definitions code="at0008">
                    <items id="text">Pain/discomfort</items>
                    <items id="description">Issues of pain or discomfort.</items>
                </term_definitions>
                <term_definitions code="at0009">
                    <items id="text">Anxiety/depression</items>
                    <items id="description">Issue with anxiety or depression.</items>
                </term_definitions>
                <term_definitions code="at0010">
                    <items id="text">Overall health</items>
                    <items id="description">A self-assessment of overall health on a scale from 0 to 100.</items>
                </term_definitions>
                <term_definitions code="at0011">
                    <items id="text">State</items>
                    <items id="description">A 5-digit code formed from the scores of each component, with 9 indicating a missing value.</items>
                    <items id="comment">e.g. '21491'</items>
                </term_definitions>
                <term_definitions code="at0012">
