                <archetype_id>
                    <value>openEHR-EHR-OBSERVATION.kpsq_vas.v0</value>
                </archetype_id>
                <term_definitions code="at0000">
                    <items id="text">Knee pain and stiffness VAS questionnaire (KPSQ-VAS)</items>
                    <items id="description">A patient-reported outcome measure used to record the intensity of pain and stiffness in the index knee and, where applicable, the contralateral knee using 0–10 visual analogue scale ratings.</items>
                </term_definitions>
                <term_definitions code="at0001">
                    <items id="text">History</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0002">
                    <items id="text">Any point-in-time event</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0003">
                    <items id="text">Tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0004">
                    <items id="text">For the knee to be operated on or already operated on</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0005">
                    <items id="text">For the other knee / the healthy side</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0006">
                    <items id="text">1. What was the intensity of the pain in your knee during the past week?</items>
                    <items id="description"></items>
                    <items id="comment">higher values indicate worse symptoms
0 = no pain / no stiffness
10 = worst imaginable pain / extreme stiffness
</items>
                </term_definitions>
                <term_definitions code="at0007">
                    <items id="text">2. What was the intensity of the stiffness in your knee during the past week?</items>
                    <items id="description"></items>
                    <items id="comment">higher values indicate worse symptoms
0 = no pain / no stiffness
10 = worst imaginable pain / extreme stiffness</items>
                </term_definitions>
                <term_definitions code="at0008">
                    <items id="text">1. What was the intensity of the pain in your knee during the past week?</items>
                    <items id="description"></items>
                    <items id="comment">higher values indicate worse symptoms
0 = no pain / no stiffness
10 = worst imaginable pain / extreme stiffness</items>
                </term_definitions>
                <term_definitions code="at0009">
                    <items id="text">2. What was the intensity of the stiffness in your knee during the past week?</items>
                    <items id="description"></items>
                    <items id="comment">higher values indicate worse symptoms
0 = no pain / no stiffness
10 = worst imaginable pain / extreme stiffness</items>
                </term_definitions>
                <term_definitions code="at0010">
                    <items id="text">Item tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
            </children>
