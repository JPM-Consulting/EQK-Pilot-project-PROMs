                <archetype_id>
                    <value>openEHR-EHR-EVALUATION.eq_5d_5l_index_score.v0</value>
                </archetype_id>
                <term_definitions code="at0000">
                    <items id="text">EQ 5D 5L Index Score</items>
                    <items id="description">To calculate an EQ-5D-5L score, first identify the 5-digit health state bycombining the individual's responses for each of the five dimensions (Mobility, Self-care, Usual Activities, Pain/Discomfort, Anxiety/Depression), with eachdigit representing a level from 1 (no problems) to 5 (extreme problems). Then, subtract the sum of the value weights for each response from 1, using a country-specific value set that assigns a specific weight to each health state. The result is a single index score between -0.594 and 1, where 1 indicates full health and values below 0 represent states worse than death.</items>
                </term_definitions>
                <term_definitions code="at0001">
                    <items id="text">Item tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0002">
                    <items id="text">Dimensions</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0006">
                    <items id="text">Mobility weighted</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0007">
                    <items id="text">Self-care weighted</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0008">
                    <items id="text">Usual activities weighted</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0009">
                    <items id="text">Pain/discomfort weighted</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0010">
                    <items id="text">Anxiety/depression weighted</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0011">
                    <items id="text">Single index score</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0012">
                    <items id="text">Index Score</items>
                    <items id="description">Subtract the sum of the value weights for each response from 1, using a country-specific value set that assigns a specific weight to each health state. The result is a single index score between -0.594 and 1, where 1 indicates full health and values below 0 represent states worse than death.</items>
                </term_definitions>
                <term_definitions code="at0013">
                    <items id="text">Item tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0014">
                    <items id="text">Extension</items>
                    <items id="description"></items>
                </term_definitions>
            </children>
