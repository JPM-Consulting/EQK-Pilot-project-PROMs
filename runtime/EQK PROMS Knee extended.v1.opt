    <component_ontologies archetype_id="openEHR-EHR-OBSERVATION.eq_5d_5l.v0">
        <term_definitions language="fr-ch">
            <items code="at0000">
                <items id="text">EQ-5D-5L État de santé</items>
                <items id="description">Une mesure standardisée de l’état de santé destinée à fournir un indicateur simple et générique de la santé pour les évaluations cliniques et économiques.</items>
            </items>
