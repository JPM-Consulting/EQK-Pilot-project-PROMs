                <term_definitions code="at0042">
                    <items id="text">Pain score raw</items>
                    <items id="description">Untransformed sum (0-16) of the four KOOS-12 Pain items (each scored 0-4; higher = worse). Compute only if &gt;= 2 of 4 items are answered; if 1-2 items are missing, impute each missing value with the mean of the answered Pain items and flag that imputation was applied.</items>
                    <items id="comment">This value is the basis for the transformed Pain score (0-100, higher = better).</items>
                </term_definitions>
