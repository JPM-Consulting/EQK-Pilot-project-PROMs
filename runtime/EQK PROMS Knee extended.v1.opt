                <items id="description"></items>
            </items>
            <items code="at0037">
                <items id="text">Pas douloureux du tout</items>
                <items id="description"></items>
            </items>
            <items code="at0044">
                <items id="text">11. Avez-vous pu faire seul(e) les courses du ménage?</items>
                <items id="description"></items>
            </items>
            <items code="at0056">
                <items id="text">6. Avez-vous boité en marchant à cause de votre genou?</items>
