                <term_definitions code="at0072">
                    <items id="text">Function score raw</items>
                    <items id="description">Untransformed sum (0-16) of the four KOOS-12 Function items (each scored 0-4; higher = worse). Compute only if &gt;= 2 of 4 items are answered; if 1-2 items are missing, impute each missing value with the mean of the answered Function items and flag that imputation was applied.</items>
                    <items id="comment">This value is the basis for the transformed Function score (0-100, higher = better).</items>
                </term_definitions>
                <term_definitions code="at0073">
                    <items id="text">Function score transformed</items>
                    <items id="description">Linearly transformed Function domain score on a 0-100 scale (100 = best, 0 = worst), calculated as 100 - (raw_sum / 16 * 100) from the Function raw score (0-16).</items>
                </term_definitions>
                <term_definitions code="at0075">
