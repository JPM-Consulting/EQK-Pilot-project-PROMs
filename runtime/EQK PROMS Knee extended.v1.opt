                <archetype_id>
                    <value>openEHR-EHR-OBSERVATION.oxford_knee.v0</value>
                </archetype_id>
                <term_definitions code="at0000">
                    <items id="text">Oxford Knee Questionnaire Score (OKS)</items>
                    <items id="description">Oxford Knee Questionnaire Score (OKS).</items>
                </term_definitions>
                <term_definitions code="at0001">
                    <items id="text">Event Series</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0002">
                    <items id="text">Any point-in-time event</items>
                    <items id="description">A specific date and/or time which may be explicitly defined in a template or at run-time.</items>
                </term_definitions>
                <term_definitions code="at0003">
                    <items id="text">Tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0005">
                    <items id="text">Tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0006">
                    <items id="text">Extension</items>
                    <items id="description">Additional information required to capture local context or to align with other reference models/formalisms.</items>
                    <items id="comment">e.g. Local hospital departmental infomation or additional metadata to align with HL7 or CDISC equivalents.</items>
                </term_definitions>
                <term_definitions code="at0008">
                    <items id="text">1. How would you describe the pain you usually have from your knee?</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0009">
                    <items id="text">Moderate</items>
                    <items id="description">The patient has experienced moderate pain in knee during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0010">
                    <items id="text">Mild</items>
                    <items id="description">The patient has experienced mild pain in knee during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0011">
                    <items id="text">Very mild</items>
                    <items id="description">The patient has experienced very mild pain in knee during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0012">
                    <items id="text">None</items>
                    <items id="description">The patient has experienced no pain in knee during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0014">
                    <items id="text">2. Have you had any trouble with washing and drying yourself (all over) because of your knee?</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0015">
                    <items id="text">Extreme difficulty</items>
                    <items id="description">The patient has extreme difficulty trouble washing and drying in the last 4 weeks because of pain in the knee.</items>
                </term_definitions>
                <term_definitions code="at0016">
                    <items id="text">Aucune difficulté</items>
                    <items id="description">The patient has no trouble washing and drying in the last 4 weeks because of pain in the knee.</items>
                </term_definitions>
                <term_definitions code="at0017">
                    <items id="text">Très peu de difficultés</items>
                    <items id="description">The patient has little trouble washing and drying in the last 4 weeks because of pain in the knee.</items>
                </term_definitions>
                <term_definitions code="at0018">
                    <items id="text">Difficultés modérées</items>
                    <items id="description">The patient has moderate trouble washing and drying in the last 4 weeks because of pain in the knee.</items>
                </term_definitions>
                <term_definitions code="at0019">
                    <items id="text">Impossible to do</items>
                    <items id="description">The patient has could not do washing and drying in the last 4 weeks because of pain in the knee.</items>
                </term_definitions>
                <term_definitions code="at0020">
                    <items id="text">3. Have you had any trouble getting in and out of a car or using public transport because of your knee? (whichever you tend to use)</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0021">
                    <items id="text">Impossible to do</items>
                    <items id="description">The patient found it impossible to get into a vehicle during the past 4 weeks due to pain in knee.</items>
                </term_definitions>
                <term_definitions code="at0022">
                    <items id="text">Extreme difficulty</items>
                    <items id="description">The patient has extreme difficulty at all getting into a vehicle during the past 4 weeks due to pain in knee.</items>
                </term_definitions>
                <term_definitions code="at0023">
                    <items id="text">Moderate trouble</items>
                    <items id="description">The patient has moderate trouble at all getting into a vehicle during the past 4 weeks due to pain in knee.</items>
                </term_definitions>
                <term_definitions code="at0024">
                    <items id="text">Very little trouble</items>
                    <items id="description">The patient has very little trouble at all getting into a vehicle during the past 4 weeks due to pain in knee.</items>
                </term_definitions>
                <term_definitions code="at0025">
                    <items id="text">No trouble at all</items>
                    <items id="description">The patient has no trouble at all getting into a vehicle during the past 4 weeks due to pain in knee.</items>
                </term_definitions>
                <term_definitions code="at0026">
                    <items id="text">4. For how long have you been able to walk before pain from your knee becomes severe? (with or without a stick)</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0027">
                    <items id="text">Not at all - pain severe when walking</items>
                    <items id="description">The patient cannot walk before pain from the knee becomes severe.</items>
                </term_definitions>
                <term_definitions code="at0028">
                    <items id="text">Around the house only</items>
                    <items id="description">The patient can walk around the house before pain from the knee becomes severe.</items>
                </term_definitions>
                <term_definitions code="at0029">
                    <items id="text">5 to 15 minutes</items>
                    <items id="description">The patient can walk 5 to 15 minutes before pain from the knee becomes severe.</items>
                </term_definitions>
                <term_definitions code="at0030">
                    <items id="text">16 to 30 minutes</items>
                    <items id="description">The patient can walk 16 to 30 minutes before pain from the knee becomes severe.</items>
                </term_definitions>
                <term_definitions code="at0031">
                    <items id="text">No pain/More than 30 minutes</items>
                    <items id="description">The patient can walk without pain or for more than 30 minutes before pain from the knee becomes severe.</items>
                </term_definitions>
                <term_definitions code="at0032">
                    <items id="text">5. After a meal (sat at a table), how painful has it been for you to stand up from a chair because of your knee?</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0033">
                    <items id="text">Unbearable</items>
                    <items id="description">The patient found it unbearable to stand up from a table after a meal in the past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0034">
                    <items id="text">Very painful</items>
                    <items id="description">The patient found it very painful to stand up from a table after a meal in the past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0035">
                    <items id="text">Moderately painful</items>
                    <items id="description">The patient found it moderately painful to stand up from a table after a meal in the past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0036">
                    <items id="text">Slightly painful</items>
                    <items id="description">The patient found it slightly painful to stand up from a table after a meal in the past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0037">
                    <items id="text">Not at all painful</items>
                    <items id="description">The patient did not find it painful to stand up from a table after a meal in the past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0044">
                    <items id="text">11. Could you do the household shopping on your own?</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0056">
                    <items id="text">6. Have you been limping when walking, because of your knee?</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0057">
                    <items id="text">All of the time</items>
                    <items id="description">The patient has been limping when walking all of the time, because of knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0058">
                    <items id="text">Most of the time</items>
                    <items id="description">The patient has been limping when walking most of the time, because of knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0059">
                    <items id="text">Often, not just at first</items>
                    <items id="description">The patient has been limping when walking often, not just at first, because of knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0060">
                    <items id="text">Sometimes, or just at first</items>
                    <items id="description">The patient has been limping when walking sometimes, or just at first, because of knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0061">
                    <items id="text">Rarely / never</items>
                    <items id="description">The patient has been rarely / never been limping when walking, because of knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0062">
                    <items id="text">10. Have you felt that your knee might suddenly 'give way' or let you down?</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0063">
                    <items id="text">All of the time</items>
                    <items id="description">The patient felt their knee might suddenly give way all of the time during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0064">
                    <items id="text">Most of the time</items>
                    <items id="description">The patient felt their knee might suddenly give way most of the time during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0065">
                    <items id="text">Often, not just at first</items>
                    <items id="description">The patient felt their knee might suddenly give way often, not just at first during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0066">
                    <items id="text">Sometimes, or just at first</items>
                    <items id="description">The patient felt their knee might suddenly give way sometimes, or just at first during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0067">
                    <items id="text">Rarely/never</items>
                    <items id="description">The patient felt their knee might suddenly give way rarely/never during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0068">
                    <items id="text">9. How much has pain from your knee interfered with your usual work (including housework)?</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0069">
                    <items id="text">Totally</items>
                    <items id="description">The patient reports that knee pain has interfered totally with their work in last 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0070">
                    <items id="text">Greatly</items>
                    <items id="description">The patient reports that knee pain has interfered greatly with their work in last 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0071">
                    <items id="text">Moderately</items>
                    <items id="description">The patient reports that knee pain has interfered moderately with their work in last 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0072">
                    <items id="text">A little bit</items>
                    <items id="description">The patient reports that knee pain has interfered a little bit with their work in last 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0073">
                    <items id="text">Not at all</items>
                    <items id="description">The patient reports that knee pain has not interfered with their work in last 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0074">
                    <items id="text">8. Have you been troubled by pain from your knee in bed at night?</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0075">
                    <items id="text">Every night</items>
                    <items id="description">The patient has experienced knee pain every night in past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0076">
                    <items id="text">Most nights</items>
                    <items id="description">The patient has experienced knee pain most nights in past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0077">
                    <items id="text">Some nights</items>
                    <items id="description">The patient has experienced knee pain some nights in past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0078">
                    <items id="text">Only 1 or 2 nights</items>
                    <items id="description">The patient has experienced knee pain only 1 or 2 nights in past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0079">
                    <items id="text">No nights</items>
                    <items id="description">The patient has experienced knee pain no nights in past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0104">
                    <items id="text">Total score</items>
                    <items id="description">Total score from Questions 1 to 12.</items>
                    <items id="comment">The overall composite score is reached by simply summing the scores received for individual questions. This results in a continuous score ranging from 0 (most severe symptoms) to 48 (least symptoms).</items>
                </term_definitions>
                <term_definitions code="at0105">
                    <items id="text">Average score</items>
                    <items id="description">Average score from Questions 1-12.</items>
                </term_definitions>
                <term_definitions code="at0109">
                    <items id="text">Severe</items>
                    <items id="description">The patient has experienced severe pain in knee during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0110">
                    <items id="text">No, impossible</items>
                    <items id="description">The patient found it impossible to climb stairs due to knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0111">
                    <items id="text">With extreme difficulty</items>
                    <items id="description">The patient found it extremely difficult to climb stairs due to knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0112">
                    <items id="text">With moderate difficulty</items>
                    <items id="description">The patient found it moderately difficult to climb stairs due to knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0113">
                    <items id="text">With little difficulty</items>
                    <items id="description">The patient found it a little difficult to climb stairs due to knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0114">
                    <items id="text">Yes, easily</items>
                    <items id="description">The patient found it they could easily climb stairs due to knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0115">
                    <items id="text">Grading</items>
                    <items id="description">*</items>
                </term_definitions>
                <term_definitions code="at0116">
                    <items id="text">Severe</items>
                    <items id="description">May indicate severe hip arthritis.</items>
                </term_definitions>
                <term_definitions code="at0117">
                    <items id="text">Moderate to severe</items>
                    <items id="description">May indicate moderate to severe hip arthritis.</items>
                </term_definitions>
                <term_definitions code="at0118">
                    <items id="text">Moderate</items>
                    <items id="description">May indicate mild to moderate hip arthritis.</items>
                </term_definitions>
                <term_definitions code="at0119">
                    <items id="text">Satisfactory</items>
                    <items id="description">May indicate satisfactory joint function.</items>
                </term_definitions>
                <term_definitions code="at0120">
                    <items id="text">7. Could you kneel down and get up again afterwards?</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0121">
                    <items id="text">No impossible</items>
                    <items id="description">The patient finds it impossible to kneel and get up again, because of knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0122">
                    <items id="text">With extreme difficulty</items>
                    <items id="description">The patient was able to kneel and get up again with extreme difficulty, because of knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0123">
                    <items id="text">With moderate difficulty</items>
                    <items id="description">The patient was able to kneel and get up again with moderate difficulty, because of knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0124">
                    <items id="text">With little difficulty</items>
                    <items id="description">The patient was able to kneel and get up again with little difficulty, because of knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0125">
                    <items id="text">Yes, easily</items>
                    <items id="description">The patient was able to kneel and get up again easily, because of knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0126">
                    <items id="text">12. Could you walk down one flight of stairs?</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0127">
                    <items id="text">No, impossible</items>
                    <items id="description">The patient found it impossible to walk down stairs due to knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0128">
                    <items id="text">With extreme difficulty</items>
                    <items id="description">The patient found it extremely difficult to walk down stairs due to knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0129">
                    <items id="text">With moderate difficulty</items>
                    <items id="description">The patient found it moderately difficult to walk down stairs due to knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0130">
                    <items id="text">With little difficulty</items>
                    <items id="description">The patient found it a little difficult to walk down stairs due to knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0131">
                    <items id="text">Yes, easily</items>
                    <items id="description">The patient found it they could easily walk down stairs due to knee pain during past 4 weeks.</items>
                </term_definitions>
                <term_definitions code="at0132">
                    <items id="text">Pain Score</items>
                    <items id="description">The OKS pain component consists of 7 items: questions 1, 4, 5, 6, 8, 9, 10</items>
                </term_definitions>
                <term_definitions code="at0133">
                    <items id="text">Function Score</items>
                    <items id="description">The OKS functional component consists of 5 items: questions 2, 3, 7, 11, 12</items>
                </term_definitions>
                <term_definitions code="at0134">
                    <items id="text">Normalized pain score</items>
                    <items id="description"></items>
                    <items id="comment">To convert the raw score to the recommended 0-100 metric:
100/maximum possible domain score X actual (raw) score i.e. 100/24 X raw score.</items>
                </term_definitions>
                <term_definitions code="at0135">
                    <items id="text">Normalized function score</items>
                    <items id="description"></items>
                    <items id="comment">To convert the raw score to the recommended 0-100 metric:
100/maximum possible domain score X actual (raw) score i.e. 100/24 X raw score.</items>
                </term_definitions>
            </children>
