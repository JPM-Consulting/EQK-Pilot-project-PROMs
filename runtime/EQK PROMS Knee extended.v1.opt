            </items>
            <items code="at0009">
                <items id="text">Anxiéte / dépression</items>
                <items id="description">Problème d’anxiété ou de dépression.</items>
            </items>
            <items code="at0010">
                <items id="text">Santé en générale</items>
                <items id="description">Auto-évaluation de l’état de santé global sur une échelle de 0 à 100.</items>
            </items>
            <items code="at0011">
                <items id="text">État de santé</items>
                <items id="description">Code à cinq chiffres obtenu à partir des scores de chaque composant, où le 9 indique une valeur manquante.</items>
                <items id="comment">p. ex. '21491'</items>
            </items>
