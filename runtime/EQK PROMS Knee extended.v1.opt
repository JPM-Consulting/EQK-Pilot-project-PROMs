    <component_ontologies archetype_id="openEHR-EHR-OBSERVATION.koos_12.v0">
        <term_definitions language="fr-ch">
            <items code="at0000">
                <items id="text">Knee Injury and Osteoarthritis Outcome Score - Short Form (KOOS-12)</items>
                <items id="description">Mesure des résultats rapportés par les patients (PROM) capturant les 12 items du KOOS-12 dans trois domaines (douleur, fonction, qualité de vie). Les réponses brutes aux items (0-4) sont enregistrées ; les scores par domaine sont calculés en additionnant les notes et en les transformant linéairement en une échelle de 0 à 100 (plus le score est élevé, meilleur est le résultat). Le score résumé de l'impact sur le genou (0 à 100) est la moyenne non pondérée des scores des trois domaines et n'est pas calculé si l'un des scores de domaine est manquant ; chaque domaine nécessite ≥ 2/4 réponses avec imputation pour les éléments manquants.</items>
            </items>
            <items code="at0001">
                <items id="text">History</items>
                <items id="description">@ internal @</items>
            </items>
            <items code="at0002">
                <items id="text">Point in time</items>
                <items id="description"></items>
            </items>
            <items code="at0003">
                <items id="text">Tree</items>
                <items id="description">@ internal @</items>
            </items>
            <items code="at0004">
                <items id="text">Douleur</items>
                <items id="description"></items>
            </items>
            <items code="at0005">
                <items id="text">1. Fréquence douleur genou</items>
                <items id="description">Question: 1. À quelle fréquence ressentez-vous des douleurs au genou?</items>
                <items id="comment">Chaque libellé de champ de données doit être court et concis ; la question posée au patient figure dans la section Description.</items>
            </items>
            <items code="at0006">
                <items id="text">Jamais</items>
                <items id="description"></items>
            </items>
            <items code="at0007">
