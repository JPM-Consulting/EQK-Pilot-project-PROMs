                <term_definitions code="at0149">
                    <items id="text">Quality of life score raw</items>
                    <items id="description">Untransformed sum (0-16) of the four KOOS-12 Quality of life items (each scored 0-4; higher = worse). Compute only if &gt;= 2 of 4 items are answered; if 1-2 items are missing, impute each missing value with the mean of the answered Quality of life items and flag that imputation was applied.</items>
                    <items id="comment">This value is the basis for the transformed Quality of life score (0-100, higher = better).</items>
                </term_definitions>
                <term_definitions code="at0150">
                    <items id="text">Quality of life  score transformed</items>
                    <items id="description">Linearly transformed Quality of life domain score on a 0-100 scale (100 = best, 0 = worst), calculated as 100 - (raw_sum / 16 * 100) from the Quality of life raw score (0-16).</items>
                </term_definitions>
                <term_definitions code="at0151">
                    <items id="text">Pain score transformed</items>
                    <items id="description">Linearly transformed Pain domain score on a 0-100 scale (100 = best, 0 = worst), calculated as 100 - (raw_sum / 16 * 100) from the Pain raw score (0-16).</items>
                </term_definitions>
                <term_definitions code="at0155">
                    <items id="text">Scoring transformed</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0159">
                    <items id="text">Extension</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0161">
                    <items id="text">General instructions</items>
                    <items id="description">INSTRUCTIONS: This survey asks for your views about your knee. Please tick only one box per question. If you are unsure about how to answer a question, please give the best answer you can.</items>
                    <items id="comment">Have “INSTRUCTIONS:” in bold font.</items>
                </term_definitions>
                <term_definitions code="at0164">
                    <items id="text">Instruction</items>
                    <items id="description">What amount of knee pain have you experienced the last week during the following activities?</items>
                    <items id="comment">Have “last week” in bold font.

Explanatory note displayed between question 1 (How often do you experience knee pain?) and question 2 (Walking on a flat surface) of the questionnaire.</items>
                </term_definitions>
                <term_definitions code="at0165">
                    <items id="text">What amount of knee pain have you experienced the last week during the following activities?</items>
                    <items id="description"></items>
                </term_definitions>
            </children>
            <cardinality>
                <is_ordered>false</is_ordered>
                <is_unique>false</is_unique>
                <interval>
                    <lower_included>true</lower_included>
                    <upper_included>false</upper_included>
                    <lower_unbounded>false</lower_unbounded>
                    <upper_unbounded>true</upper_unbounded>
                    <lower>1</lower>
                </interval>
            </cardinality>
        </attributes>
