                <term_definitions code="at0000">
                    <items id="text">Knee Injury and Osteoarthritis Outcome Score - Short Form (KOOS-12)</items>
                    <items id="description">Patient-reported outcome measure (PROM) capturing the 12-item KOOS-12 across three domains (Pain, Function, Quality of Life). Raw item responses (0–4) are stored; domain scores are computed by summated ratings and linearly transformed to 0–100 (higher = better). The Summary knee impact score (0–100) is the unweighted mean of the three domain scores and is not calculated if any domain score is missing; each domain requires ≥2/4 items answered with imputation for missing items.</items>
                </term_definitions>
                <term_definitions code="at0001">
