                <items id="description"></items>
            </items>
            <items code="at0012">
                <items id="text">Aucune</items>
                <items id="description"></items>
            </items>
            <items code="at0014">
                <items id="text">2. Avez-vous eu des difficultés à vous laver et à vous sécher entièrement à cause de votre genou?</items>
                <items id="description"></items>
            </items>
            <items code="at0015">
                <items id="text">Difficultés majeures</items>
                <items id="description"></items>
            </items>
            <items code="at0016">
