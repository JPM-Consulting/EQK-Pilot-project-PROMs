                <items id="description"></items>
            </items>
            <items code="at0020">
                <items id="text">3. Avez-vous eu des difficultés, à cause de votre genou, pour monter dans une voiture et en sortir ou pour utiliser les transports publics (selon le moyen de transport que vous utilisez habituellement)?</items>
                <items id="description"></items>
            </items>
            <items code="at0021">
                <items id="text">Impossible à réaliser</items>
                <items id="description"></items>
            </items>
            <items code="at0022">
                <items id="text">Difficultés majeures</items>
                <items id="description"></items>
            </items>
            <items code="at0023">
                <items id="text">Difficultés modérées</items>
                <items id="description"></items>
            </items>
            <items code="at0024">
                <items id="text">Difficultés minimes</items>
                <items id="description"></items>
            </items>
            <items code="at0025">
                <items id="text">Aucune difficulté</items>
                <items id="description"></items>
            </items>
            <items code="at0026">
                <items id="text">4. Pendant combien de temps avez-vous pu marcher avant que la douleur de votre genou ne devienne importante? (avec ou sans canne)</items>
                <items id="description"></items>
            </items>
            <items code="at0027">
                <items id="text">Pas du tout ou douleur sévère à la marche</items>
                <items id="description"></items>
            </items>
            <items code="at0028">
                <items id="text">Autour de la maison seulement</items>
                <items id="description"></items>
            </items>
            <items code="at0029">
                <items id="text">De 5 à 15 minutes</items>
                <items id="description"></items>
            </items>
            <items code="at0030">
                <items id="text">De 16 à 30 minutes</items>
                <items id="description"></items>
            </items>
            <items code="at0031">
                <items id="text">Pas de douleur ou plus de 30 minutes</items>
                <items id="description"></items>
            </items>
            <items code="at0032">
                <items id="text">5. Après un repas (assis(e) à table), dans quelle mesure était-il douloureux pour vous de vous lever d’une chaise à cause de votre genou?</items>
                <items id="description"></items>
            </items>
            <items code="at0033">
                <items id="text">Insupportable</items>
                <items id="description"></items>
            </items>
            <items code="at0034">
