                <term_definitions code="at0000">
                    <items id="text">EQ-5D-5L Health status</items>
                    <items id="description">A standardised measure of health status to provide a simple, generic measure of health for clinical and economic appraisal.</items>
                </term_definitions>
                <term_definitions code="at0001">
                    <items id="text">Event Series</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0002">
