                <archetype_id>
                    <value>openEHR-EHR-OBSERVATION.ucla_activity_level_rating.v0</value>
                </archetype_id>
                <term_definitions code="at0000">
                    <items id="text">UCLA activity level rating</items>
                    <items id="description">A patient-reported outcome measure used to record the current physical activity level using the UCLA activity level rating.</items>
                </term_definitions>
                <term_definitions code="at0001">
                    <items id="text">History</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0002">
                    <items id="text">Any point-in-time event</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0003">
                    <items id="text">Tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0004">
                    <items id="text">Activity level</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0005">
                    <items id="text">Wholly inactive: dependent on others; cannot leave residence</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0006">
                    <items id="text">Mostly inactive: restricted to minimal activities of daily living</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0007">
                    <items id="text">Sometimes participate in mild activities</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0008">
                    <items id="text">Regularly participate in mild activities, such as walking, limited housework, and limited shopping</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0009">
                    <items id="text">Sometimes participate in moderate activities</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0010">
                    <items id="text">Regularly participate in moderate activities, such as swimming and unlimited housework or shopping</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0011">
                    <items id="text">Regularly participate in active events, such as bicycling</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0012">
                    <items id="text">Regularly participate in very active events, such as bowling or golf</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0013">
                    <items id="text">Sometimes participate in impact sports</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0014">
                    <items id="text">Regularly participate in impact sports such as jogging, tennis, skiing, acrobatics, ballet, heavy labor, or backpacking</items>
                    <items id="description"></items>
                </term_definitions>
            </children>
